{
  "name": "@iof/obp-demo-server",
  "version": "1.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Open Bank Project Demo Server for Islamic Open Finance",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node --env-file=../../.env dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@iof/service-core": "workspace:*",
    "hono": "^4.12.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
